# ─────────────────────────────────────────────────────────────
# DATABASE + AUTH
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

STRIPE_STANDARD_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TRIAL_PRICE_ID=price_...        # $15 paid trial price

# ─────────────────────────────────────────────────────────────
# ANTHROPIC
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────
# UNIPILE — email send/receive via client OAuth
# ─────────────────────────────────────────────────────────────
UNIPILE_API_KEY=
UNIPILE_BASE_URL=https://api.unipile.com:9443
UNIPILE_OAUTH_REDIRECT=http://localhost:3000/api/unipile/oauth-callback

# ─────────────────────────────────────────────────────────────
# REPHONIC — podcast discovery
# ─────────────────────────────────────────────────────────────
REPHONIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# RESEND — transactional + onboarding emails (NEW v3)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hi@podpick.com
ADMIN_NOTIFICATION_EMAIL=hi@podpick.com

# ─────────────────────────────────────────────────────────────
# INNGEST — background jobs (NEW v3)
# ─────────────────────────────────────────────────────────────
# Get from https://app.inngest.com/settings/event-keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─────────────────────────────────────────────────────────────
# QUOTAS (NEW v3 — env-driven, not hardcoded)
# ─────────────────────────────────────────────────────────────
STANDARD_QUOTA=10
PRO_QUOTA=25

# ─────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Podpick
NEXT_PUBLIC_BRAND_TAGLINE=Hand-written podcast pitches for bootstrapped SaaS founders

# ─────────────────────────────────────────────────────────────
# ADMIN SEED (dev only — used by db:seed)
# ─────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=courage@example.com
SEED_ADMIN_NAME=Courage

# ─────────────────────────────────────────────────────────────
# OBSERVABILITY
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
